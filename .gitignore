# =========================================================================
# Lofi Space Station — Git Global Ignore Configuration (.gitignore)
# =========================================================================

# 1. 의존성 패키지 (Dependency packages)
node_modules/
/node_modules/
frontend/node_modules/
backend/node_modules/

# 2. 로컬 환경 설정 파일 (Sensitive environment keys - 보안 핵심)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local
frontend/.env
backend/.env.local

# 3. 대용량 미디어 파일 및 수급 음원 (Large asset files - 500MB+ push block 방어)
# (음원은 깃허브에 올리지 않고 배포 서버에서 download-lofi.js 스크립트로 직접 구축합니다)
/backend/media/music/
/backend/media/music/*
backend/media/music/
media/music/
*.mp3

# 4. 프론트엔드 프로덕션 빌드 결과물 (Production build artifacts)
/frontend/dist/
/frontend/build/
dist/
build/

# 5. 로컬 IDE / OS 캐시 (IDE and OS caches)
.vscode/
.idea/
.project
.settings/
.DS_Store
Thumbs.db
desktop.ini

# 6. 컴파일 캐시 및 런타임 로그 (Compile caches and runtime logs)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.vite/
.turbo/
.cache/
