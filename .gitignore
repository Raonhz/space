# =========================================================================
# Lofi Space Station — Git Global Ignore Configuration (.gitignore)
# =========================================================================

# 1. 의존성 패키지 (Dependency packages)
node_modules/
/node_modules/
next-lofi/node_modules/

# 2. 환경 설정 파일 (Sensitive environment keys - 보안 핵심)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# 3. 대용량 미디어 파일 및 에셋 (Large asset files - 500MB+ 방어)
*.mp3
*.mp4
*.webp
/next-lofi/public/music/
/next-lofi/public/video/

# 4. Next.js 빌드 결과물 (Next.js build artifacts)
/next-lofi/.next/
/next-lofi/out/

# 5. 로컬 IDE / OS 캐시 (IDE and OS caches)
.vscode/
.idea/
.project
.settings/
.DS_Store
Thumbs.db
desktop.ini

# 6. 컴파일 캐시 및 런타임 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.turbo/
.cache/